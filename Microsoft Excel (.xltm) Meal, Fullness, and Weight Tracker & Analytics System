' ==========================================================
'  Meal, Fullness, and Weight Tracker & Analytics System
'  Designed for Personalized Medicine & Complete Clinical Screening
' ==========================================================

Sub ShowMealForm()
    Dim inputDate As Variant, mealType As Variant
    Dim strStaple As String, strMain As String, strSide As String
    Dim strFullness As String, strWeight As String, strExercise As String
    Dim staple As Integer, main As Integer, side As Integer
    Dim fullness As Integer, weight As Double, exercise As Integer
    Dim totalCount As Integer
    Dim lastRow As Long
    
    ' 1. Initialize Sheet1 (Creates headers if they do not exist)
    Call InitializeSheet
    lastRow = Sheets("Sheet1").Cells(Rows.Count, 1).End(xlUp).Row + 1
    
    ' 2. User Input via Dialogs (With strict input validation)
    ' --- Date ---
    inputDate = InputBox("Please enter the date.", "1. Date Input", Date)
    If inputDate = "" Then Exit Sub
    If Not IsDate(inputDate) Then
        MsgBox "Invalid date format. Registration canceled.", vbExclamation, "Error"
        Exit Sub
    End If
    
    ' --- Meal Type ---
    mealType = InputBox("Enter Meal Type:" & vbCrLf & "1: Breakfast, 2: Lunch, 3: Dinner, 4: Snack", "1b. Meal Type", 1)
    If mealType = "" Then Exit Sub
    Select Case mealType
        Case "1": mealType = "Breakfast"
        Case "2": mealType = "Lunch"
        Case "3": mealType = "Dinner"
        Case "4": mealType = "Snack"
        Case Else: mealType = "Other"
    End Select
    
    ' --- Counts & Fullness ---
    strStaple = InputBox("Enter [Staple Food] count (0 if skipped)." & vbCrLf & "Guide: 1 bowl of rice, 1 slice of bread, 1 serving of noodles", "2. Staple Food Count", "0")
    If strStaple = "" Then Exit Sub
    If Not IsNumeric(strStaple) Then GoTo InvalidNumeric
    staple = CInt(strStaple)
    
    strMain = InputBox("Enter [Main Dish] count (0 if skipped)." & vbCrLf & "Guide: 1 plate of meat, 1 piece of fish, 1 egg dish, 1 soy product dish", "3. Main Dish Count", "0")
    If strMain = "" Then Exit Sub
    If Not IsNumeric(strMain) Then GoTo InvalidNumeric
    main = CInt(strMain)
    
    strSide = InputBox("Enter [Side Dish] count (0 if skipped)." & vbCrLf & "Guide: 1 plate of salad, 1 small bowl/cup, 1 cup of vegetable soup", "4. Side Dish Count", "0")
    If strSide = "" Then Exit Sub
    If Not IsNumeric(strSide) Then GoTo InvalidNumeric
    side = CInt(strSide)
    
    strFullness = InputBox("Enter [Fullness Level] IMMEDIATELY after the meal." & vbCrLf & "5: Overeating, 3: Appropriate, 1: Almost empty, 0: Skipped meal", "5. Fullness Level (0-5)", "3")
    If strFullness = "" Then Exit Sub
    If Not IsNumeric(strFullness) Then GoTo InvalidNumeric
    fullness = CInt(strFullness)
    If fullness < 0 Or fullness > 5 Then
        MsgBox "Fullness level must be between 0 and 5.", vbExclamation, "Error"
        Exit Sub
    End If
    
    ' --- Weight & Exercise ---
    strWeight = InputBox("Enter current [Weight (kg)] (Same time daily, preferably morning)", "6. Body Weight", "")
    If strWeight = "" Then Exit Sub
    If Not IsNumeric(strWeight) Then GoTo InvalidNumeric
    weight = CDbl(strWeight)
    
    strExercise = InputBox("Enter [Exercise Intensity] for today (Optional)." & vbCrLf & "5: High, 3: Moderate, 1: Sedentary", "7. Exercise Intensity (1-5)", "3")
    If strExercise = "" Then Exit Sub
    If Not IsNumeric(strExercise) Then GoTo InvalidNumeric
    exercise = CInt(strExercise)

    ' 3. Mathematical Logic & Data Processing
    totalCount = staple + main + side
    
    ' Write data to Sheet1
    With Sheets("Sheet1")
        .Cells(lastRow, 1).Value = CDate(inputDate)
        .Cells(lastRow, 2).Value = mealType
        .Cells(lastRow, 3).Value = staple
        .Cells(lastRow, 4).Value = main
        .Cells(lastRow, 5).Value = side
        .Cells(lastRow, 6).Value = totalCount
        
        ' Compositional Data Analysis
        If totalCount > 0 Then
            .Cells(lastRow, 7).Value = (staple / totalCount) * 100
            .Cells(lastRow, 8).Value = (main / totalCount) * 100
            .Cells(lastRow, 9).Value = (side / totalCount) * 100
        Else
            .Cells(lastRow, 7).Value = 0
            .Cells(lastRow, 8).Value = 0
            .Cells(lastRow, 9).Value = 0
        End If
        
        .Cells(lastRow, 10).Value = fullness
        .Cells(lastRow, 11).Value = weight
        .Cells(lastRow, 12).Value = exercise
    End With
    
    MsgBox "Data successfully recorded.", vbInformation, "Success"
    
    ' 4. Clinical Logic: Full Red Flag Monitoring
    Call CheckRedFlags(lastRow, weight)
    Exit Sub

InvalidNumeric:
    MsgBox "Please enter a valid numbers. Registration canceled.", vbExclamation, "Error"
End Sub

' ── Initial Sheet Configuration ──
Sub InitializeSheet()
    Dim ws As Worksheet
    Set ws = Sheets("Sheet1")
    If ws.Cells(1, 1).Value = "" Then
        ws.Cells(1, 1).Resize(1, 12).Value = Array( _
            "Date", "Meal Type", "Staple Count", "Main Dish Count", "Side Dish Count", "Total Count", _
            "Dietary Balance (Staple %)", "Dietary Balance (Main %)", "Dietary Balance (Side %)", _
            "Fullness Level", "Weight (kg)", "Exercise Intensity")
        ws.Rows(1).Font.Bold = True
        ws.Columns("A:L").AutoFit
    End If
End Sub

' ── Clinical Alert Engine ──
Sub CheckRedFlags(currentRow As Long, currentWeight As Double)
    Dim ws As Worksheet
    Dim i As Long
    Dim checkDate As Date
    Dim pastWeight As Double
    Dim weightDrop1Month As Boolean
    Dim weightDrop6Month As Boolean
    Dim weightGainSudden As Boolean
    
    Set ws = Sheets("Sheet1")
    checkDate = ws.Cells(currentRow, 1).Value
    
    weightDrop1Month = False
    weightDrop6Month = False
    weightGainSudden = False
    
    ' Scan past data (From closest to oldest)
    For i = currentRow - 1 To 2 Step -1
        ' --- 1) Evaluation for Unintentional Weight Loss ---
        ' Check 1-month window (28 to 35 days ago)
        If Not weightDrop1Month Then
            If ws.Cells(i, 1).Value >= checkDate - 35 And ws.Cells(i, 1).Value <= checkDate - 28 Then
                pastWeight = ws.Cells(i, 11).Value ' Adjusted for column shift
                If pastWeight > 0 And (pastWeight - currentWeight) >= 4.5 Then
                    weightDrop1Month = True
                End If
            End If
        End If
        
        ' Check 6-month window (170 to 190 days ago)
        If Not weightDrop6Month Then
            If ws.Cells(i, 1).Value >= checkDate - 190 And ws.Cells(i, 1).Value <= checkDate - 170 Then
                pastWeight = ws.Cells(i, 11).Value
                If pastWeight > 0 And ((pastWeight - currentWeight) / pastWeight) >= 0.05 Then
                    weightDrop6Month = True
                End If
            End If
        End If
        
        ' --- 2) Evaluation for Unintentional Weight Gain ---
        ' Check short-term sudden increase (within the last 3 to 7 days)
        If Not weightGainSudden Then
            If ws.Cells(i, 1).Value >= checkDate - 7 And ws.Cells(i, 1).Value <= checkDate - 3 Then
                pastWeight = ws.Cells(i, 11).Value
                If pastWeight > 0 And (currentWeight - pastWeight) >= 2.0 Then
                    weightGainSudden = True
                End If
            End If
        End If
    Next i
    
    ' Trigger Red Flag Warnings
    If weightDrop1Month Then
        MsgBox "【⚠️ CRITICAL MEDICAL ALERT: RED FLAG DETECTED】" & vbCrLf & _
               "Unintentional weight loss of 4.5 kg or more within 1 month detected, while diet and exercise remain stable." & vbCrLf & _
               "Possible risks include malignancy (cancer), Graves' disease, worsening diabetes, or malabsorption. Immediate medical consultation is highly recommended.", vbCritical, "Unintentional Weight Loss"
    
    ElseIf weightDrop6Month Then
        MsgBox "【⚠️ CRITICAL MEDICAL ALERT: RED FLAG DETECTED】" & vbCrLf & _
               "Unintentional weight loss of 5% or more within 6 months detected, while diet and exercise remain stable." & vbCrLf & _
               "Possible risks include malignancy (cancer), Graves' disease, worsening diabetes, or malabsorption. Immediate medical consultation is highly recommended.", vbCritical, "Unintentional Weight Loss"
    
    ElseIf weightGainSudden Then
        MsgBox "【⚠️ CRITICAL MEDICAL ALERT: RED FLAG DETECTED】" & vbCrLf & _
               "Unintentional rapid weight gain detected, while diet and exercise remain stable." & vbCrLf & _
               "Possible risks include acute heart failure, kidney failure, liver failure (edematous disorders), or hypothyroidism. Immediate medical consultation is highly recommended.", vbCritical, "Unintentional Weight Gain"
    End If
End Sub
